# ============================================================================
# Discord Bot Configuration
# ============================================================================
# Get your bot token from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# ============================================================================
# Majestic RP API Configuration (Optional)
# ============================================================================
# Base URL for Majestic RP API (default: https://api.majestic-rp.com)
# MAJESTIC_API_BASE_URL=https://api.majestic-rp.com

# ============================================================================
# Bot Settings (Optional)
# ============================================================================
# Bot status text (default: "маркетплейс Majestic RP")
# BOT_STATUS=маркетплейс Majestic RP

# ============================================================================
# Logging Configuration (Optional)
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
# LOG_LEVEL=INFO

# ============================================================================
# Instructions:
# ============================================================================
# 1. Copy this file to .env: cp .env.example .env
# 2. Replace 'your_discord_bot_token_here' with your actual Discord bot token
# 3. Save the file
# 4. Run the bot: python main.py
# ============================================================================